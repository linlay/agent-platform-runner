# Server
# Host port exposed by compose.yml (container listens on 8080)
HOST_PORT=11949
# Optional app port for non-docker local runs (mvn spring-boot:run)
# SERVER_PORT=8080

# Auth
AGENT_AUTH_ENABLED=true
# Supported verification modes:
# 1) Local public key file (default). Relative paths resolve under runner configs/ when not absolute.
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=local-public-key.pem
# 2) JWKS. If you want JWKS-only mode, set AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=
#    and then configure all three values below together.
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=
# AGENT_AUTH_JWKS_CACHE_SECONDS=300

# Chat image token
CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
# CHAT_IMAGE_TOKEN_PREVIOUS_SECRETS=
# CHAT_IMAGE_TOKEN_TTL_SECONDS=86400
CHAT_IMAGE_TOKEN_DATA_TOKEN_VALIDATION_ENABLED=false

# Container Hub
AGENT_CONTAINER_HUB_BASE_URL=http://host.docker.internal:11960

# Runtime directories used by both `make run` and `docker compose`.
# Most directories may stay relative to this repo, or point to directories outside the repo.
# Local runs read these values directly.
# Docker Compose uses them as host bind-mount sources and also exposes them as container env vars,
# while the docker profile keeps Spring's in-container paths fixed under /opt/*.
# Every `*_DIR` below may also be set to an absolute host path when needed.
# If sandbox_bash talks to a host-side Container Hub, prefer real host-accessible paths here.
# If omitted, registries default to `./runtime/registries` and the rest default to `./runtime/*`.
# If you externalize the dynamic registries to a shared host root, keep naming them under:
#   <base>/registries/{providers,models,mcp-servers,viewport-servers}
# REGISTRIES_DIR=./runtime/registries
# OWNER_DIR=./runtime/owner
# AGENTS_DIR=./runtime/agents
# TEAMS_DIR=./runtime/teams
# ROOT_DIR=./runtime/root
# SCHEDULES_DIR=./runtime/schedules
# CHATS_DIR=./runtime/chats
# PAN_DIR=./runtime/pan
# SKILLS_MARKET_DIR=./runtime/skills-market

# Structured YAML config lives under runner ./configs.
# Keep live host registries separate from templates, for example under
# .zenmind/registries/* and .zenmind/example.registries/*.
# Copy the real files you need from the existing *.example.yml / *.example.pem templates before startup.
