# Server
# Host port exposed by docker-compose (container listens on 8080)
HOST_PORT=11949
# Optional app port for non-docker local runs (mvn spring-boot:run)
# SERVER_PORT=8080

# Auth
AGENT_AUTH_ENABLED=true
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=
# AGENT_AUTH_JWKS_CACHE_SECONDS=300
# Optional: PEM file path, resolved relative to CONFIGS_DIR when not absolute
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=auth/local-public-key.pem

# Chat image token
CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
# CHAT_IMAGE_TOKEN_PREVIOUS_SECRETS=
# CHAT_IMAGE_TOKEN_TTL_SECONDS=86400
CHAT_IMAGE_TOKEN_DATA_TOKEN_VALIDATION_ENABLED=false

# Runtime directories used by both `make run` and `docker compose`.
# They can stay relative to this repo, or point to directories outside the repo.
# CONFIGS_DIR=./configs
# AGENTS_DIR=./agents
# TEAMS_DIR=./teams
# MODELS_DIR=./models
# PROVIDERS_DIR=./providers
# TOOLS_DIR=./tools
# MCP_SERVERS_DIR=./mcp-servers
# VIEWPORT_SERVERS_DIR=./viewport-servers
# VIEWPORTS_DIR=./viewports
# SKILLS_DIR=./skills
# SCHEDULES_DIR=./schedules
# DATA_DIR=./data
# CHATS_DIR=./chats

# Structured YAML config lives under ./configs.
# Copy the real files you need from the existing *.example.yml / *.example.pem templates before startup.
