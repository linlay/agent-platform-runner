# Server
# Host port exposed by docker-compose (container listens on 8080)
HOST_PORT=11949
# Optional app port for non-docker local runs (mvn spring-boot:run)
# SERVER_PORT=8080

# Auth
AGENT_AUTH_ENABLED=false
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=

# LLM provider accounts are configured in application.yml.
# For multiple providers/accounts, keep structured config under:
#   agent.providers.*
