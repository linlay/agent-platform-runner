# Server
# Host port exposed by docker-compose (container listens on 8080)
HOST_PORT=11949
# Optional app port for non-docker local runs (mvn spring-boot:run)
# SERVER_PORT=8080

# Auth
AGENT_AUTH_ENABLED=true
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=
# AGENT_AUTH_JWKS_CACHE_SECONDS=300
# Optional: PEM file path, resolved relative to AGENT_CONFIG_DIR when not absolute
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=auth/local-public-key.pem

# Chat image token
CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
# CHAT_IMAGE_TOKEN_PREVIOUS_SECRETS=
# CHAT_IMAGE_TOKEN_TTL_SECONDS=86400
# CHAT_IMAGE_TOKEN_DATA_TOKEN_VALIDATION_ENABLED=true

# Optional: override config directory root. Defaults to ./configs for local scripts.
# AGENT_CONFIG_DIR=./configs

# Structured YAML config lives under ./configs.
# Copy *.example.yml/*.example.pem to real files before startup, for example:
#   cp configs/bash.example.yml configs/bash.yml
#   cp configs/voice-tts.example.yml configs/voice-tts.yml
#   cp configs/providers/bailian.example.yml configs/providers/bailian.yml
