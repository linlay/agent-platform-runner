# Release bundle runtime
RUNNER_VERSION=__RUNNER_VERSION__
HOST_PORT=11949

# Auth
AGENT_AUTH_ENABLED=true
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=
# AGENT_AUTH_JWKS_CACHE_SECONDS=300
# Optional: PEM file path inside ./configs when not absolute
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=local-public-key.pem

# Chat image token
CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
# CHAT_IMAGE_TOKEN_PREVIOUS_SECRETS=
# CHAT_IMAGE_TOKEN_TTL_SECONDS=86400
CHAT_IMAGE_TOKEN_DATA_TOKEN_VALIDATION_ENABLED=false

# Container Hub
AGENT_CONTAINER_HUB_BASE_URL=http://host.docker.internal:11960

# Host paths used by the release bundle compose file.
# The four dynamic registry directories default to `./runtime/registries/*`.
# If you externalize them to a shared host root, keep naming them as:
#   <base>/registries/providers
#   <base>/registries/models
#   <base>/registries/mcp-servers
#   <base>/registries/viewport-servers
# Keep example/template files outside the live registry tree, for example under:
#   <base>/example.registries/providers
#   <base>/example.registries/models
#   <base>/example.registries/mcp-servers
#   <base>/example.registries/viewport-servers
PROVIDERS_DIR=./runtime/registries/providers
MODELS_DIR=./runtime/registries/models
MCP_SERVERS_DIR=./runtime/registries/mcp-servers
VIEWPORT_SERVERS_DIR=./runtime/registries/viewport-servers
OWNER_DIR=./runtime/owner
AGENTS_DIR=./runtime/agents
TEAMS_DIR=./runtime/teams
ROOT_DIR=./runtime/root
SCHEDULES_DIR=./runtime/schedules
CHATS_DIR=./runtime/chats
PAN_DIR=./runtime/pan
SKILLS_MARKET_DIR=./runtime/skills-market
