{
  "tools": [
    {
      "type": "function",
      "name": "datetime",
      "description": "获取当前或偏移后的日期时间，支持可选 timezone 和链式 offset，输出包含农历",
      "parameters": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "可选时区，支持 IANA zoneId 或 UTC+8、+08:00、Z 等偏移表示"
          },
          "offset": {
            "type": "string",
            "description": "可选链式时间偏移，例如 +1D、+1D-3H+20M、-2y、+3w；不填或 0 表示当前时间"
          }
        },
        "additionalProperties": false
      }
    }
  ]
}
