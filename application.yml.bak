server:
  port: 11949

agent:
  mcp-servers:
    enabled: true
  tools:
    bash:
      # 低权限模式（默认生效）：保留基础命令白名单与路径校验。
      # working-directory: ${user.dir}
      # allowed-paths: ${user.dir},/tmp
      # allowed-commands: ls,pwd,cat,head,tail,top,free,df,git,rg,find
      # path-checked-commands: ls,cat,head,tail,git,rg,find
      # path-check-bypass-commands: git
      # shell-features-enabled: false
      # shell-executable: bash
      # shell-timeout-ms: 10000
      # max-command-chars: 16000
      # 高权限模式（注释模板，按需手动切换）：
      # 1) 将下列注释行复制替换上面的低权限值；
      # 2) bypass 仅对 allowed-commands 交集生效（命令未放行时 bypass 不生效）。
      working-directory: ${user.home}
      allowed-paths: ${user.dir},${user.home}/Project,${user.home}/Server,/tmp,/dev/null
      allowed-commands: ls,pwd,cat,head,tail,top,free,df,git,rg,find,grep,wc,curl
      path-checked-commands: ls,cat,head,tail,git,rg,find,grep,wc,curl
      path-check-bypass-commands: git,curl,ls,find,grep,wc
      shell-features-enabled: true
      shell-executable: bash
      shell-timeout-ms: 10000
      max-command-chars: 16000
  # schedule 默认值已由内置 application.yml 提供（external-dir/enabled/pool-size）。
  # 如需统一时区，可仅覆盖 default-zone-id；留空则使用系统时区。
  voice:
    ws:
      enabled: true
      path: /api/ap/ws/voice
      auth-required: false
      codecs:
        - pcm
        - opus
      max-session-seconds: 300
      default-sample-rate: 24000
      default-channels: 1
    tts:
      provider: aliyun
      aliyun:
        endpoint: wss://dashscope.aliyuncs.com/api-ws/v1/realtime
        api-key: sk-630760c3585e4182b4687456093e0e00
        model: qwen3-tts-instruct-flash-realtime
        voice: Maia
        language-type: Auto
        mode: server_commit
        format: pcm
        sample-rate: 24000
        speech-rate: 1.2
        volume: 50
        pitch-rate: 1.0
        bit-rate: 128
        response-format: PCM_24000HZ_MONO_16BIT
        instructions:
        optimize-instructions: false
        session-finished-timeout-ms: 120000
        log-sent-chunk-enabled: false
  auth:
    enabled: true
    local-public-key: |
      -----BEGIN PUBLIC KEY-----
      MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA5g/GvtR1Go8KP589M0Uu
      KrbzhJcDh6nlBtBmKdJxapEzZx7rMD0IeWwrtOF+V/wgL7oW3ybZWCh6c8EA/WWP
      CEaGKmpMc8Kh7E100dAX+LVnNCn53vJ3/7a1FQw1SPuRHNxQwRh5CpAtpu/qJVTe
      3TMPgxOtf4Fk8hwYaNOz3jGppU1boDQW8F2d27FrQimbfNNzyeJbt3iRbsF2w8V4
      lb4yO1gEIPsbdpG0V+XRMyUyXcUxZQRhTI0pTmdvSVJTnYT7RBTw8hxLObrNHTdU
      H/De0+xpy+S42ExBbd0TgB5bop0P5dtqPi4JilY30VaCdhu/NxlnQYqLYgtm9ohx
      dQIDAQAB
      -----END PUBLIC KEY-----
  chat-image-token:
    secret: ap_chat_image
    ttl-seconds: 86400
  providers:
    bailian:
      base-url: https://dashscope.aliyuncs.com/compatible-mode
      api-key: sk-630760c3585e4182b4687456093e0e00
      model: qwen3-max
    siliconflow:
      base-url: https://api.siliconflow.cn
      api-key: sk-hnhnkwdtefarlmwdjvryfyuaixzayjcirggykxvqqagrkokl
      model: deepseek-ai/DeepSeek-V3.2
    babelark:
      base-url: https://babelark.com/
      api-key: sk-g5y344NHN9eBktWX0EpfLrAiou7JIZZAVjJ8BmrOXlf7PFiK
